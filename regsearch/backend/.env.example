# --- Qdrant ---
# Local (docker-compose): http://qdrant:6333  |  Local (host): http://localhost:6333
QDRANT_URL=http://localhost:6333
# Only needed for Qdrant Cloud; leave blank for local.
QDRANT_API_KEY=
COLLECTION_NAME=reg_documents

# --- Models (downloaded on first use, then cached) ---
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
RERANKER_MODEL=Xenova/ms-marco-MiniLM-L-6-v2

# --- Retrieval tuning ---
BM25_K1=1.5
BM25_B=0.75
RRF_K=60
CANDIDATE_POOL=30
DEFAULT_TOP_K=10

# --- CORS: the deployed frontend origin ---
CLIENT_URL=http://localhost:5173
